{
  "$id": "urn:discrepancy-desk:m06a.normalized-package.srt.v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "coverage": {
      "type": "object"
    },
    "elements": {
      "type": "array"
    },
    "encoding": {
      "enum": [
        "utf-8",
        "utf-16-le",
        "utf-16-be"
      ]
    },
    "line_ending_profile": {
      "type": "string"
    },
    "parser_admission_id": {
      "type": "string"
    },
    "parser_config_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "parser_id": {
      "const": "m06a.srt.v1"
    },
    "parser_implementation_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "parser_implementation_version": {
      "type": "string"
    },
    "regions": {
      "type": "array"
    },
    "schema_version": {
      "const": "m06a.normalized-package.srt.v1"
    },
    "security_profile_id": {
      "type": "string"
    },
    "source_artifact_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "vault_account_id": {
      "type": "string"
    },
    "warnings": {
      "items": {
        "enum": [
          "encoding_bom_removed",
          "line_ending_normalized",
          "nonsequential_cue_index",
          "overlapping_cues"
        ]
      },
      "type": "array"
    }
  },
  "required": [
    "coverage",
    "elements",
    "encoding",
    "line_ending_profile",
    "parser_admission_id",
    "parser_config_sha256",
    "parser_id",
    "parser_implementation_sha256",
    "parser_implementation_version",
    "regions",
    "schema_version",
    "security_profile_id",
    "source_artifact_sha256",
    "vault_account_id",
    "warnings"
  ],
  "title": "M06-A deterministic SRT normalized package",
  "type": "object"
}
